@startuml
skinparam componentStyle rectangle
skinparam defaultFontSize 10

title Архитектура блокчейн-системы с адаптивным шардированием

package "API и интеграция" #LightBlue {
  [REST API] as rest_api
  [KYC/AML] as kyc
}

package "Хранилище" #LightGreen {
  [Блокчейн] as blockchain
  [Пул транзакций] as txpool
}

package "Адаптивное шардирование" #LightYellow {
  [AdaptiveShardingManager] as shard_mgr
  [ARIMA-прогнозист] as arima
  [ShardRouter] as router
  
  package "Шарды (1-8)" {
    [Шард 1] as shard1
    [Шард N] as shardN
  }
}

package "Консенсус" #LightCyan {
  [Переключатель PoS/BFT] as switcher
  [PoS] as pos
  [BFT] as bft
}

package "Валидаторы и репутация" #LightPink {
  [Валидатор] as validator
  [Пул валидаторов] as validator_pool
  [Система репутации] as reputation
}

package "Безопасность" #LightGray {
  [Аудит безопасности] as auditor
  [Защита от двойной траты] as double_spend
  [Защита от 51% атаки] as fiftyone
  [Защита от Sybil-атак] as sybil
}

package "Говернанс" #Purple {
  [Менеджер предложений] as proposal
  [Система голосований] as voting
}

package "Мониторинг" #SkyBlue {
  [Prometheus-метрики] as monitoring
}

' ---- Основные потоки данных ----
[Внешние клиенты] --> rest_api : Транзакции
rest_api --> kyc : KYC-проверка
rest_api --> txpool : Добавление транзакций

' ---- Шардирование ----
txpool --> router : Маршрутизация
router --> shard1 : hash(tx) % N
router --> shardN : hash(tx) % N
shard_mgr --> shard1 : Управление
shard_mgr --> shardN : Управление
arima --> shard_mgr : Прогноз TPS

' ---- Консенсус ----
shard1 --> switcher : Консенсус
shardN --> switcher : Консенсус
switcher --> pos : PoS режим
switcher --> bft : BFT режим
pos --> validator_pool : Выбор валидатора
bft --> validator_pool : Выбор валидатора
validator_pool "1..N" --> validator : валидаторы
validator_pool --> reputation : вес = stake × reputation
validator --> blockchain : Добавление блоков

' ---- Безопасность ----
double_spend --> auditor : Детектирование
fiftyone --> auditor : Мониторинг stake
sybil --> auditor : Анализ поведения
auditor --> rest_api : Логи безопасности

' ---- Говернанс ----
proposal --> voting : Голосование
voting --> reputation : Обновление параметров

' ---- Мониторинг ----
monitoring --> switcher : Метрики TPS
monitoring --> shard_mgr : Статистика шардов

' ---- Обратные связи ----
blockchain --> switcher : Статус блоков
txpool --> switcher : Статус пула
validator_pool --> switcher : Статус валидаторов

note right of arima
  ARIMA(1,1,1)
  - Окно: 20 наблюдений
  - Горизонт: 5 шагов
  - Интервал: 30 сек
end note

note bottom of shard_mgr
  Пороги масштабирования
  (проектные значения):
  - Scale Up: >1000 TPS
  - Scale Down: <300 TPS
  - Диапазон: 1-8 шардов
  - Интервал: 30 сек
end note

note right of switcher
  Переключатель консенсуса:
  - Единый интерфейс для PoS и BFT
  - Без остановки системы
  - Сравнение в Главе 3
end note
@enduml